---
import { getCollection } from 'astro:content';

const allArtworks = await getCollection('artworks');
const figurativeWorks = allArtworks
  .filter(a => a.data.category === 'figurative')
  .sort((a, b) => a.data.orderIndex - b.data.orderIndex);
const abstractWorks = allArtworks
  .filter(a => a.data.category === 'abstract')
  .sort((a, b) => a.data.orderIndex - b.data.orderIndex);

// Serialize data for client-side JavaScript
const artworksData = allArtworks.map(a => ({
  slug: a.slug,
  ...a.data
}));
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Selected Works - Claus Bertermann" />
    <title>Selected Works - Claus Bertermann</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { font-family: 'Barlow', sans-serif; background-color: #ffffff; color: #111827; min-height: 100vh; }
      header { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: #ffffff; border-bottom: 1px solid rgba(0, 0, 0, 0.1); }
      .header-container { max-width: 1400px; margin: 0 auto; padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center; }
      .logo { display: flex; align-items: center; gap: 0.75rem; font-size: 1.75rem; font-weight: 300; letter-spacing: 0.1875rem; text-transform: uppercase; color: #111827; text-decoration: none; }
      .logo img { height: 28px; width: auto; }
      nav ul { display: flex; list-style: none; gap: 2.5rem; align-items: center; }
      nav li { position: relative; }
      nav a { color: #111827; text-decoration: none; font-size: 0.9375rem; font-weight: 400; letter-spacing: 0.05rem; text-transform: uppercase; transition: color 0.3s; font-family: 'Barlow', sans-serif; }
      nav a:hover { color: #6b7280; }
      .dropdown { position: relative; padding-bottom: 1rem; margin-bottom: -1rem; }
      .dropdown-content { display: none; position: absolute; top: 100%; left: 50%; transform: translateX(-50%); background: #ffffff; min-width: 160px; padding: 0.5rem 0; margin-top: 0; border: 1px solid rgba(0, 0, 0, 0.1); box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); z-index: 1000; }
      .dropdown-content::before { content: ''; position: absolute; top: -6px; left: 50%; transform: translateX(-50%); border-left: 6px solid transparent; border-right: 6px solid transparent; border-bottom: 6px solid #ffffff; }
      .dropdown:hover .dropdown-content { display: block; }
      .dropdown-content a { display: block; padding: 0.75rem 1.5rem; font-size: 0.8125rem; font-weight: 300; color: #374151; text-align: center; }
      .dropdown-content a:hover { color: #111827; background: rgba(0, 0, 0, 0.05); }
      main { padding-top: 80px; min-height: 100vh; }
      .gallery-container { max-width: 1400px; margin: 0 auto; padding: 4rem 2rem; }
      .gallery-header { margin-bottom: 3rem; }
      .gallery-header h1 { font-size: 2rem; font-weight: 300; letter-spacing: 0.05rem; text-transform: uppercase; color: #111827; }
      .filter-container { display: flex; gap: 1rem; margin-bottom: 2rem; }
      .filter-btn { background: transparent; border: 1px solid #d1d5db; color: #6b7280; padding: 0.75rem 1.5rem; font-size: 0.875rem; font-weight: 500; letter-spacing: 0.1rem; text-transform: uppercase; cursor: pointer; transition: all 0.3s; font-family: 'Barlow', sans-serif; }
      .filter-btn:hover, .filter-btn.active { border-color: #111827; color: #111827; }
      .gallery-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2rem; }
      .gallery-item { cursor: pointer; transition: transform 0.3s; }
      .gallery-item:hover { transform: translateY(-5px); }
      .gallery-item img { width: 100%; height: auto; display: block; background: #f3f4f6; border-radius: 8px; }
      .gallery-item-info { padding: 1rem 0; }
      .gallery-item-info .artist { font-size: 0.75rem; font-weight: 600; letter-spacing: 0.1rem; text-transform: uppercase; color: #6b7280; margin-bottom: 0.25rem; }
      .gallery-item-info .title { font-size: 1.1rem; font-weight: 400; margin-bottom: 0.25rem; color: #111827; }
      .gallery-item-info .details { font-size: 0.9375rem; color: #9ca3af; line-height: 1.4; }
      .lightbox { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0, 0, 0, 0.95); z-index: 1000; overflow: auto; }
      .lightbox.active { display: flex; flex-direction: column; }
      .lightbox-close { position: absolute; top: 2rem; right: 2rem; background: none; border: none; color: #ffffff; font-size: 2rem; cursor: pointer; z-index: 1001; }
      .lightbox-content { flex: 1; display: flex; align-items: center; justify-content: center; padding: 4rem; }
      .lightbox-image { max-width: 90%; max-height: 80vh; object-fit: contain; }
      .lightbox-nav { position: absolute; top: 50%; transform: translateY(-50%); background: rgba(255, 255, 255, 0.1); border: none; color: #ffffff; font-size: 2rem; width: 50px; height: 50px; border-radius: 50%; cursor: pointer; transition: background 0.3s; }
      .lightbox-nav:hover { background: rgba(255, 255, 255, 0.2); }
      .lightbox-prev { left: 2rem; }
      .lightbox-next { right: 2rem; }
      .lightbox-info { padding: 2rem; text-align: center; border-top: 1px solid rgba(255, 255, 255, 0.1); color: #ffffff; }
      .main-footer { background: #f9fafb; padding: 3rem 2rem; border-top: 1px solid #e5e7eb; }
      .footer-container { max-width: 1400px; margin: 0 auto; display: grid; grid-template-columns: repeat(3, 1fr); gap: 3rem; }
      .footer-column h3 { font-size: 0.875rem; font-weight: 500; letter-spacing: 0.1rem; text-transform: uppercase; margin-bottom: 1.5rem; color: #111827; }
      .footer-column ul { list-style: none; }
      .footer-column li { margin-bottom: 0.75rem; }
      .footer-column a { color: #6b7280; text-decoration: none; font-size: 0.875rem; transition: color 0.3s; }
      .footer-column a:hover { color: #111827; }
      .footer-bottom { max-width: 1400px; margin: 2rem auto 0; padding-top: 2rem; border-top: 1px solid #e5e7eb; text-align: center; color: #9ca3af; font-size: 0.875rem; }
      @media (max-width: 640px) { .gallery-grid { grid-template-columns: 1fr; } }
      @media (min-width: 641px) and (max-width: 1024px) { .gallery-grid { grid-template-columns: repeat(2, 1fr); } }
      @media (max-width: 768px) {
        .header-container { padding: 1rem; }
        .logo { font-size: 1rem; }
        .logo img { height: 20px; }
        nav ul { gap: 1rem; }
        nav a { font-size: 0.75rem; }
        .gallery-container { padding: 2rem 1rem; }
        .gallery-header h1 { font-size: 1.5rem; }
        .footer-container { grid-template-columns: 1fr; gap: 2rem; }
        .lightbox-content { padding: 2rem; }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="header-container">
        <a href="/" class="logo">
          <img src="/favicon.png" alt="Logo" />
          <span>Claus Bertermann</span>
        </a>
        <nav>
          <ul>
            <li class="dropdown">
              <span style="color: #111827; font-size: 0.9375rem; font-weight: 400; letter-spacing: 0.05rem; text-transform: uppercase; cursor: default;">Selected Works</span>
              <div class="dropdown-content">
                <a href="/selected-works?category=figurative">Figurative</a>
                <a href="/selected-works?category=abstract">Abstract</a>
              </div>
            </li>
            <li><a href="/bio">Bio</a></li>
            <li><a href="/events">Events</a></li>
            <li><a href="/blog">Blog</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <main>
      <div class="gallery-container">
        <div class="gallery-header">
          <h1 id="gallery-title">Selected Works</h1>
        </div>

        <div class="filter-container">
          <button class="filter-btn active" onclick="filterWorks('figurative')">Figurative</button>
          <button class="filter-btn" onclick="filterWorks('abstract')">Abstract</button>
        </div>

        <div class="gallery-grid" id="gallery-grid">
          {figurativeWorks.map((artwork, index) => (
            <div class="gallery-item" onclick={`openLightbox(${index})`}>
              <img src={artwork.data.image} alt={artwork.data.altText || artwork.data.title} loading="lazy" style="border-radius: 8px;" />
              <div class="gallery-item-info">
                <div class="artist">CLAUS BERTERMANN</div>
                <div class="title">{artwork.data.title} ({artwork.data.year})</div>
                <div class="details">{artwork.data.size}, {artwork.data.materials}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </main>

    <!-- Lightbox -->
    <div class="lightbox" id="lightbox">
      <button class="lightbox-close" onclick="closeLightbox()">&times;</button>
      <button class="lightbox-nav lightbox-prev" onclick="prevImage()">&lt;</button>
      <div class="lightbox-content">
        <img src="" alt="" class="lightbox-image" id="lightbox-img">
      </div>
      <button class="lightbox-nav lightbox-next" onclick="nextImage()">&gt;</button>
      <div class="lightbox-info" id="lightbox-info"></div>
    </div>

    <!-- Footer -->
    <footer class="main-footer">
      <div class="footer-container">
        <div class="footer-column">
          <h3>Quick Links</h3>
          <ul>
            <li><a href="/selected-works">Selected Works</a></li>
            <li><a href="/bio">Bio</a></li>
            <li><a href="/events">Events</a></li>
            <li><a href="/blog">Blog</a></li>
            <li><a href="/contact">Contact</a></li>
            <li><a href="/legal">Legal</a></li>
          </ul>
        </div>
        <div class="footer-column">
          <h3>Shop</h3>
          <ul>
            <li><a href="https://www.1stdibs.com/dealers/claus-bertermann/" target="_blank" rel="noopener noreferrer">Claus Bertermann on 1stDibs</a></li>
          </ul>
        </div>
        <div class="footer-column">
          <h3>Follow Us</h3>
          <ul>
            <li><a href="https://www.instagram.com/clausbertermann/" target="_blank" rel="noopener noreferrer">Instagram</a></li>
            <li><a href="https://www.linkedin.com/in/clausbertermann/" target="_blank" rel="noopener noreferrer">LinkedIn</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 <span style="text-transform: uppercase; letter-spacing: 0.1rem;">Claus Bertermann</span>. All rights reserved.</p>
      </div>
    </footer>

    <script define:vars={{ artworksData }}>
      // Artworks data from Astro content collection
      const artworks = artworksData;

      let currentCategory = 'figurative';
      let currentImageIndex = 0;
      let currentImages = [];

      function cmToInches(cm) {
        const match = cm.match(/(\d+)\s*×\s*(\d+)\s*cm/);
        if (match) {
          const width = (parseInt(match[1]) / 2.54).toFixed(1);
          const height = (parseInt(match[2]) / 2.54).toFixed(1);
          return `${width} × ${height}`;
        }
        return '';
      }

      function getTitle(category) {
        return category === 'figurative' ? 'Figurative Works' : 'Abstract Works';
      }

      function renderGallery(category) {
        const grid = document.getElementById('gallery-grid');
        const title = document.getElementById('gallery-title');
        const items = artworks.filter(a => a.category === category);
        
        title.textContent = getTitle(category);
        
        grid.innerHTML = items.map((artwork, index) => `
          <div class="gallery-item" onclick="openLightbox(${index})">
            <img src="${artwork.image}" alt="${artwork.altText || artwork.title}" loading="lazy" style="border-radius: 8px;">
            <div class="gallery-item-info">
              <div class="artist">CLAUS BERTERMANN</div>
              <div class="title">${artwork.title} (${artwork.year})</div>
              <div class="details">${artwork.size}, ${artwork.materials}</div>
            </div>
          </div>
        `).join('');
      }

      function filterWorks(category) {
        currentCategory = category;
        document.querySelectorAll('.filter-btn').forEach(btn => {
          btn.classList.toggle('active', btn.textContent.toLowerCase() === category);
        });
        renderGallery(category);
      }

      function openLightbox(index) {
        currentImages = artworks.filter(a => a.category === currentCategory);
        currentImageIndex = index;
        updateLightbox();
        document.getElementById('lightbox').classList.add('active');
        document.body.style.overflow = 'hidden';
      }

      function closeLightbox() {
        document.getElementById('lightbox').classList.remove('active');
        document.body.style.overflow = '';
      }

      function updateLightbox() {
        const artwork = currentImages[currentImageIndex];
        document.getElementById('lightbox-img').src = artwork.image;
        document.getElementById('lightbox-img').alt = artwork.altText || artwork.title;
        document.getElementById('lightbox-info').innerHTML = `
          <div class="artist">CLAUS BERTERMANN</div>
          <div class="title">${artwork.title} (${artwork.year})</div>
          <div class="details">${artwork.size}, ${artwork.materials}</div>
        `;
      }

      function nextImage() {
        currentImageIndex = (currentImageIndex + 1) % currentImages.length;
        updateLightbox();
      }

      function prevImage() {
        currentImageIndex = (currentImageIndex - 1 + currentImages.length) % currentImages.length;
        updateLightbox();
      }

      function checkUrlCategory() {
        const urlParams = new URLSearchParams(window.location.search);
        const category = urlParams.get('category');
        if (category === 'figurative' || category === 'abstract') {
          filterWorks(category);
        } else {
          renderGallery('figurative');
        }
      }

      checkUrlCategory();

      document.addEventListener('keydown', (e) => {
        if (!document.getElementById('lightbox').classList.contains('active')) return;
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowRight') nextImage();
        if (e.key === 'ArrowLeft') prevImage();
      });

      document.getElementById('lightbox').addEventListener('click', (e) => {
        if (e.target.id === 'lightbox') closeLightbox();
      });
    </script>
  </body>
</html>
