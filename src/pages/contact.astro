<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Contact - Claus Bertermann" />
    <title>Contact - Claus Bertermann</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      
      body {
        font-family: 'Barlow', sans-serif;
        background-color: #ffffff;
        color: #111827;
        min-height: 100vh;
      }
      
      /* Header */
      header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        background: #ffffff;
        border-bottom: 1px solid rgba(0, 0, 0, 0.1);
      }
      
      .header-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 1rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      
      .logo {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 1.75rem;
        font-weight: 300;
        letter-spacing: 0.1875rem;
        text-transform: uppercase;
        color: #111827;
        text-decoration: none;
      }
      
      .logo img {
        height: 28px;
        width: auto;
      }
      
      nav ul {
        display: flex;
        list-style: none;
        gap: 2.5rem;
        align-items: center;
      }
      
      nav li {
        position: relative;
      }
      
      nav a {
        color: #111827;
        text-decoration: none;
        font-size: 0.9375rem;
        font-weight: 400;
        letter-spacing: 0.05rem;
        text-transform: uppercase;
        transition: color 0.3s;
        font-family: 'Barlow', sans-serif;
      }
      
      nav a:hover {
        color: #6b7280;
      }
      
      /* Dropdown Menu */
      .dropdown {
        position: relative;
        padding-bottom: 1rem;
        margin-bottom: -1rem;
      }
      
      .dropdown-content {
        display: none;
        position: absolute;
        top: 100%;
        left: 50%;
        transform: translateX(-50%);
        background: #ffffff;
        min-width: 160px;
        padding: 0.5rem 0;
        margin-top: 0;
        border: 1px solid rgba(0, 0, 0, 0.1);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        z-index: 1000;
      }
      
      .dropdown-content::before {
        content: '';
        position: absolute;
        top: -6px;
        left: 50%;
        transform: translateX(-50%);
        border-left: 6px solid transparent;
        border-right: 6px solid transparent;
        border-bottom: 6px solid #ffffff;
      }
      
      .dropdown:hover .dropdown-content {
        display: block;
      }
      
      .dropdown-content a {
        display: block;
        padding: 0.75rem 1.5rem;
        font-size: 0.8125rem;
        font-weight: 300;
        color: #374151;
        text-align: center;
      }
      
      .dropdown-content a:hover {
        color: #111827;
        background: rgba(0, 0, 0, 0.05);
      }
      
      /* Main Content */
      main {
        padding-top: 80px;
        min-height: 100vh;
      }
      
      /* Contact Section */
      .contact-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 4rem 2rem;
      }
      
      .contact-header {
        margin-bottom: 3rem;
      }
      
      .contact-header h1 {
        font-size: 2rem;
        font-weight: 300;
        letter-spacing: 0.05rem;
        text-transform: uppercase;
        margin-bottom: 0.5rem;
        color: #111827;
      }
      
      .contact-header .subtitle {
        font-size: 1.25rem;
        font-weight: 300;
        color: #6b7280;
      }
      
      .contact-intro {
        margin-bottom: 3rem;
      }
      
      .contact-intro p {
        font-size: 1.1rem;
        font-weight: 300;
        line-height: 1.8;
        color: #374151;
        margin-bottom: 1.5rem;
      }
      
      .contact-intro a {
        font-weight: 600;
        text-decoration: underline;
        color: #111827;
      }
      
      .contact-intro a:hover {
        color: #6b7280;
      }
      
      /* Contact Content Layout */
      .contact-content {
        display: grid;
        grid-template-columns: 400px 1fr;
        gap: 4rem;
        align-items: start;
      }
      
      .contact-image {
        width: 100%;
        border-radius: 8px;
        overflow: hidden;
      }
      
      .contact-image img {
        width: 100%;
        height: auto;
        display: block;
      }
      
      /* Contact Form */
      .contact-form {
        max-width: 600px;
      }
      
      .form-group {
        margin-bottom: 1.5rem;
      }
      
      .form-group label {
        display: block;
        font-size: 0.875rem;
        font-weight: 400;
        color: #374151;
        margin-bottom: 0.5rem;
        text-transform: uppercase;
        letter-spacing: 0.05rem;
      }
      
      .form-group input,
      .form-group textarea {
        width: 100%;
        padding: 0.875rem 1rem;
        border: 1px solid #d1d5db;
        font-family: 'Barlow', sans-serif;
        font-size: 1rem;
        color: #111827;
        background: #ffffff;
        transition: border-color 0.3s;
      }
      
      .form-group input:focus,
      .form-group textarea:focus {
        outline: none;
        border-color: #111827;
      }
      
      .form-group textarea {
        min-height: 150px;
        resize: vertical;
      }
      
      .textarea-wrapper {
        position: relative;
      }
      
      .char-counter {
        position: absolute;
        bottom: 0.5rem;
        right: 0.75rem;
        font-size: 0.75rem;
        color: #9ca3af;
      }
      
      .submit-btn {
        width: 100%;
        padding: 1rem 2rem;
        background: #111827;
        color: #ffffff;
        border: none;
        font-family: 'Barlow', sans-serif;
        font-size: 0.9375rem;
        font-weight: 400;
        letter-spacing: 0.1rem;
        text-transform: uppercase;
        cursor: pointer;
        transition: background 0.3s;
      }
      
      .submit-btn:hover {
        background: #374151;
      }
      
      /* Footer */
      .main-footer {
        background: #f9fafb;
        padding: 3rem 2rem;
        border-top: 1px solid #e5e7eb;
      }
      
      .footer-container {
        max-width: 1400px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 3rem;
      }
      
      .footer-column h3 {
        font-size: 0.875rem;
        font-weight: 500;
        letter-spacing: 0.1rem;
        text-transform: uppercase;
        margin-bottom: 1.5rem;
        color: #111827;
      }
      
      .footer-column ul {
        list-style: none;
      }
      
      .footer-column li {
        margin-bottom: 0.75rem;
      }
      
      .footer-column a {
        color: #6b7280;
        text-decoration: none;
        font-size: 0.875rem;
        transition: color 0.3s;
      }
      
      .footer-column a:hover {
        color: #111827;
      }
      
      .footer-bottom {
        max-width: 1400px;
        margin: 2rem auto 0;
        padding-top: 2rem;
        border-top: 1px solid #e5e7eb;
        text-align: center;
        color: #9ca3af;
        font-size: 0.875rem;
      }
      
      /* Responsive */
      @media (max-width: 968px) {
        .contact-content {
          grid-template-columns: 1fr;
          gap: 2rem;
        }
        
        .contact-image {
          max-width: 400px;
        }
      }
      
      @media (max-width: 768px) {
        .header-container {
          padding: 1rem;
        }
        
        .logo {
          font-size: 1rem;
        }
        
        .logo img {
          height: 20px;
        }
        
        nav ul {
          gap: 1rem;
        }
        
        nav a {
          font-size: 0.75rem;
        }
        
        .contact-container {
          padding: 2rem 1rem;
        }
        
        .contact-header h1 {
          font-size: 1.5rem;
        }
        
        .footer-container {
          grid-template-columns: 1fr;
          gap: 2rem;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="header-container">
        <a href="/" class="logo">
          <img src="/favicon.png" alt="Logo" />
          <span>Claus Bertermann</span>
        </a>
        <nav>
          <ul>
            <li class="dropdown">
              <span style="color: #111827; font-size: 0.9375rem; font-weight: 400; letter-spacing: 0.05rem; text-transform: uppercase; cursor: default;">Selected Works</span>
              <div class="dropdown-content">
                <a href="/selected-works?category=figurative">Figurative</a>
                <a href="/selected-works?category=abstract">Abstract</a>
              </div>
            </li>
            <li><a href="/bio">Bio</a></li>
            <li><a href="/events">Events</a></li>
            <li><a href="/blog">Blog</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <main>
      <div class="contact-container">
        <div class="contact-header">
          <h1>Get in Touch</h1>
          <p class="subtitle">Contact Claus Bertermann</p>
        </div>

        <div class="contact-intro">
          <p>Use this space to ask questions about existing works or to inquire about commissions. Claus Bertermann welcomes commissions and enjoys creating bespoke pieces tailored to your vision. Please use the form on this page to share your ideas, or contact the studio directly at <a href="mailto:claus@bertermann.art">claus@bertermann.art</a></p>
        </div>

        <div class="contact-content">
          <div class="contact-image">
            <img src="/images/contact-photo.jpg" alt="Claus Bertermann" />
          </div>

          <form class="contact-form" action="mailto:claus@bertermann.art" method="post" enctype="text/plain">
            <div class="form-group">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" required />
            </div>
            
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" required />
            </div>
            
            <div class="form-group">
              <label for="subject">Subject</label>
              <input type="text" id="subject" name="subject" required />
            </div>
            
            <div class="form-group">
              <label for="message">Message</label>
              <div class="textarea-wrapper">
                <textarea id="message" name="message" maxlength="2000" required></textarea>
                <span class="char-counter" id="charCounter">2000</span>
              </div>
            </div>
            
            <button type="submit" class="submit-btn">Send Message</button>
          </form>
        </div>
      </div>
    </main>

    <!-- Footer -->
    <footer class="main-footer">
      <div class="footer-container">
        <div class="footer-column">
          <h3>Quick Links</h3>
          <ul>
            <li><a href="/selected-works">Selected Works</a></li>
            <li><a href="/bio">Bio</a></li>
            <li><a href="/events">Events</a></li>
            <li><a href="/blog">Blog</a></li>
            <li><a href="/contact">Contact</a></li>
            <li><a href="/legal">Legal</a></li>
          </ul>
        </div>
        <div class="footer-column">
          <h3>Shop</h3>
          <ul>
            <li><a href="https://www.1stdibs.com/dealers/claus-bertermann/" target="_blank" rel="noopener noreferrer">Claus Bertermann on 1stDibs</a></li>
          </ul>
        </div>
        <div class="footer-column">
          <h3>Follow Us</h3>
          <ul>
            <li><a href="https://www.instagram.com/clausbertermann/" target="_blank" rel="noopener noreferrer">Instagram</a></li>
            <li><a href="https://www.linkedin.com/in/clausbertermann/" target="_blank" rel="noopener noreferrer">LinkedIn</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 <span style="text-transform: uppercase; letter-spacing: 0.1rem;">Claus Bertermann</span>. All rights reserved.</p>
      </div>
    </footer>

    <script>
      const textarea = document.getElementById('message');
      const counter = document.getElementById('charCounter');
      const maxLength = 2000;

      textarea.addEventListener('input', function() {
        const remaining = maxLength - this.value.length;
        counter.textContent = remaining;
      });
    </script>
  </body>
</html>
