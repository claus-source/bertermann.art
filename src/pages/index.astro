<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Claus Bertermann - Contemporary Abstract and Figurative Paintings" />
    <title>Claus Bertermann - Contemporary Artist</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      
      body {
        font-family: 'Barlow', sans-serif;
        background-color: #ffffff;
        color: #111827;
        min-height: 100vh;
      }
      
      header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        background: rgba(31, 41, 55, 0.3);
        border-bottom: 1px solid rgba(255, 255, 255, 0.2);
      }
      
      .header-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 1rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      
      .logo {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 1.75rem;
        font-weight: 300;
        letter-spacing: 0.1875rem;
        text-transform: uppercase;
        color: #ffffff;
        text-decoration: none;
      }
      
      .logo img {
        height: 28px;
        width: auto;
      }
      
      nav ul {
        display: flex;
        list-style: none;
        gap: 2.5rem;
      }
      
      nav li {
        position: relative;
      }
      
      nav a {
        color: #ffffff;
        text-decoration: none;
        font-size: 0.9375rem;
        font-weight: 400;
        letter-spacing: 0.05rem;
        text-transform: uppercase;
        transition: color 0.3s;
        font-family: 'Barlow', sans-serif;
        cursor: pointer;
      }
      
      nav a:hover {
        color: #d1d5db;
      }
      
      /* Dropdown Menu */
      .dropdown {
        position: relative;
        padding-bottom: 1rem;
        margin-bottom: -1rem;
      }
      
      .dropdown-content {
        display: none;
        position: absolute;
        top: 100%;
        left: 50%;
        transform: translateX(-50%);
        background: #ffffff;
        min-width: 160px;
        padding: 0.5rem 0;
        margin-top: 0;
        border: 1px solid rgba(0, 0, 0, 0.1);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        z-index: 1000;
      }
      
      .dropdown-content::before {
        content: '';
        position: absolute;
        top: -6px;
        left: 50%;
        transform: translateX(-50%);
        border-left: 6px solid transparent;
        border-right: 6px solid transparent;
        border-bottom: 6px solid #ffffff;
      }
      
      .dropdown:hover .dropdown-content {
        display: block;
      }
      
      .dropdown-content a {
        display: block;
        padding: 0.75rem 1.5rem;
        font-size: 0.8125rem;
        font-weight: 300;
        color: #374151;
        text-align: center;
        cursor: pointer;
      }
      
      .dropdown-content a:hover {
        color: #111827;
        background: rgba(0, 0, 0, 0.05);
      }
      
      .carousel-container {
        position: relative;
        width: 100%;
        height: 100vh;
        overflow: hidden;
        z-index: 1;
      }
      
      .carousel-slide {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        opacity: 0;
        transition: opacity 1s ease-in-out;
        z-index: 1;
      }
      
      .carousel-slide.active {
        opacity: 1;
        z-index: 2;
      }
      
      .carousel-slide img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      
      .carousel-nav {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(255, 255, 255, 0.3);
        border: none;
        color: rgba(0, 0, 0, 0.7);
        font-size: 2rem;
        width: 50px;
        height: 50px;
        border-radius: 50%;
        cursor: pointer;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
      }
      
      .carousel-nav:hover {
        background: rgba(255, 255, 255, 0.5);
        color: #111827;
      }
      
      .carousel-prev {
        left: 2rem;
      }
      
      .carousel-next {
        right: 2rem;
      }
      
      .carousel-indicators {
        position: absolute;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        gap: 0.5rem;
        z-index: 100;
      }
      
      .indicator {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.5);
        cursor: pointer;
        transition: all 0.3s;
      }
      
      .indicator.active {
        background: #ffffff;
      }
      
      .hero-footer {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        background: rgba(31, 41, 55, 0.3);
        padding: 3rem 2rem 2rem;
        text-align: center;
        z-index: 10;
      }
      
      .hero-footer p {
        font-size: 1.125rem;
        font-weight: 300;
        line-height: 1.6;
        margin-bottom: 1rem;
        color: #ffffff;
      }
      
      .hero-footer .highlight {
        font-weight: 600;
        text-decoration: underline;
        color: #ffffff;
      }
      
      .hero-links {
        display: flex;
        justify-content: center;
        gap: 2rem;
      }
      
      .hero-links a {
        color: #ffffff;
        text-decoration: none;
        border-bottom: 1px solid #ffffff;
        padding-bottom: 0.25rem;
        font-size: 0.875rem;
        font-weight: 500;
        letter-spacing: 0.1rem;
        text-transform: uppercase;
        transition: all 0.3s;
      }
      
      .hero-links a:hover {
        color: #d1d5db;
        border-color: #d1d5db;
      }
      
      /* Main Footer */
      .main-footer {
        background: #f9fafb;
        padding: 3rem 2rem;
        border-top: 1px solid #e5e7eb;
      }
      
      .footer-container {
        max-width: 1400px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 3rem;
      }
      
      .footer-column h3 {
        font-size: 0.875rem;
        font-weight: 500;
        letter-spacing: 0.1rem;
        text-transform: uppercase;
        margin-bottom: 1.5rem;
        color: #111827;
      }
      
      .footer-column ul {
        list-style: none;
      }
      
      .footer-column li {
        margin-bottom: 0.75rem;
      }
      
      .footer-column a {
        color: #6b7280;
        text-decoration: none;
        font-size: 0.875rem;
        transition: color 0.3s;
      }
      
      .footer-column a:hover {
        color: #111827;
      }
      
      .footer-bottom {
        max-width: 1400px;
        margin: 2rem auto 0;
        padding-top: 2rem;
        border-top: 1px solid #e5e7eb;
        text-align: center;
        color: #9ca3af;
        font-size: 0.875rem;
      }
      
      /* Cookie Banner */
      .cookie-banner {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        background: #ffffff;
        padding: 1rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        z-index: 1000;
        box-shadow: 0 -4px 6px -1px rgba(0, 0, 0, 0.1);
        border-top: 1px solid #e5e7eb;
      }
      
      .cookie-banner.hidden {
        display: none;
      }
      
      .cookie-text {
        color: #374151;
        font-size: 0.875rem;
        font-weight: 300;
      }
      
      .cookie-text a {
        color: #374151;
        text-decoration: underline;
      }
      
      .cookie-buttons {
        display: flex;
        gap: 0.75rem;
      }
      
      .cookie-btn {
        padding: 0.5rem 1.25rem;
        font-size: 0.875rem;
        font-weight: 400;
        cursor: pointer;
        border: 1px solid #d1d5db;
        background: #ffffff;
        color: #374151;
        font-family: 'Barlow', sans-serif;
      }
      
      .cookie-btn:hover {
        background: #f3f4f6;
      }
      
      @media (max-width: 768px) {
        .header-container {
          padding: 1rem;
        }
        
        .logo {
          font-size: 1rem;
        }
        
        .logo img {
          height: 20px;
        }
        
        nav ul {
          gap: 1rem;
        }
        
        nav a {
          font-size: 0.75rem;
        }
        
        .carousel-nav {
          width: 40px;
          height: 40px;
          font-size: 1.5rem;
        }
        
        .carousel-prev {
          left: 1rem;
        }
        
        .carousel-next {
          right: 1rem;
        }
        
        .hero-footer {
          padding: 1.5rem 1rem;
        }
        
        .hero-footer p {
          font-size: 1rem;
        }
        
        .hero-links {
          flex-direction: column;
          gap: 1rem;
        }
        
        .footer-container {
          grid-template-columns: 1fr;
          gap: 2rem;
        }
        
        .cookie-banner {
          flex-direction: column;
          gap: 1rem;
          text-align: center;
        }
        
        .cookie-buttons {
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="header-container">
        <a href="/" class="logo">
          <img src="/favicon.png" alt="Logo" />
          <span>Claus Bertermann</span>
        </a>
        <nav>
          <ul>
            <li class="dropdown">
              <span style="color: #ffffff; font-size: 0.9375rem; font-weight: 400; letter-spacing: 0.05rem; text-transform: uppercase; cursor: default;">Selected Works</span>
              <div class="dropdown-content">
                <a href="/selected-works?category=figurative">Figurative</a>
                <a href="/selected-works?category=abstract">Abstract</a>
              </div>
            </li>
            <li><a href="/bio">Bio</a></li>
            <li><a href="/events">Events</a></li>
            <li><a href="/blog">Blog</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </nav>
      </div>
    </header>

    <div class="carousel-container">
      <div class="carousel-slide active">
        <img src="/images/carousel/01.png" alt="Artwork 1" />
      </div>
      <div class="carousel-slide">
        <img src="/images/carousel/02.jpg" alt="Artwork 2" />
      </div>
      <div class="carousel-slide">
        <img src="/images/carousel/03.png" alt="Artwork 3" />
      </div>
      <div class="carousel-slide">
        <img src="/images/carousel/04.png" alt="Artwork 4" />
      </div>
      <div class="carousel-slide">
        <img src="/images/carousel/05.jpg" alt="Artwork 5" />
      </div>
      <div class="carousel-slide">
        <img src="/images/carousel/06.jpg" alt="Artwork 6" />
      </div>

      <button class="carousel-nav carousel-prev" onclick="prevSlide()">&lt;</button>
      <button class="carousel-nav carousel-next" onclick="nextSlide()">&gt;</button>

      <div class="carousel-indicators">
        <span class="indicator active" onclick="goToSlide(0)"></span>
        <span class="indicator" onclick="goToSlide(1)"></span>
        <span class="indicator" onclick="goToSlide(2)"></span>
        <span class="indicator" onclick="goToSlide(3)"></span>
        <span class="indicator" onclick="goToSlide(4)"></span>
        <span class="indicator" onclick="goToSlide(5)"></span>
      </div>

      <div class="hero-footer">
        <p>
          <span class="highlight">bertermann.art</span> is the official website of contemporary artist Claus Bertermann, 
          presenting current figurative and abstract works, studio projects and authoritative updates directly from the artist.
        </p>
        <div class="hero-links">
          <a href="/bio">Learn more about the artist</a>
          <a href="/selected-works">Explore selected works</a>
        </div>
      </div>
    </div>

    <!-- Cookie Banner -->
    <div class="cookie-banner" id="cookie-banner">
      <div class="cookie-text">
        We use cookies to improve your experience and analyze website traffic. By clicking "Accept", you agree to our use of cookies. Read our <a href="/legal">Cookie Policy</a>.
      </div>
      <div class="cookie-buttons">
        <button class="cookie-btn" onclick="rejectCookies()">Reject</button>
        <button class="cookie-btn" onclick="acceptCookies()">Accept</button>
      </div>
    </div>

    <!-- Main Footer -->
    <footer class="main-footer">
      <div class="footer-container">
        <div class="footer-column">
          <h3>Quick Links</h3>
          <ul>
            <li><a href="/selected-works">Selected Works</a></li>
            <li><a href="/bio">Bio</a></li>
            <li><a href="/events">Events</a></li>
            <li><a href="/blog">Blog</a></li>
            <li><a href="/contact">Contact</a></li>
            <li><a href="/legal">Legal</a></li>
          </ul>
        </div>
        <div class="footer-column">
          <h3>Shop</h3>
          <ul>
            <li><a href="https://www.1stdibs.com/dealers/claus-bertermann/" target="_blank" rel="noopener noreferrer">Claus Bertermann on 1stDibs</a></li>
          </ul>
        </div>
        <div class="footer-column">
          <h3>Follow Us</h3>
          <ul>
            <li><a href="https://www.instagram.com/clausbertermann/" target="_blank" rel="noopener noreferrer">Instagram</a></li>
            <li><a href="https://www.linkedin.com/in/clausbertermann/" target="_blank" rel="noopener noreferrer">LinkedIn</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 <span style="text-transform: uppercase; letter-spacing: 0.1rem;">Claus Bertermann</span>. All rights reserved.</p>
      </div>
    </footer>

    <script>
      let currentSlide = 0;
      let slideInterval;
      const slides = document.querySelectorAll('.carousel-slide');
      const indicators = document.querySelectorAll('.indicator');
      const totalSlides = slides.length;

      function showSlide(index) {
        slides.forEach((slide, i) => {
          slide.classList.toggle('active', i === index);
        });
        indicators.forEach((indicator, i) => {
          indicator.classList.toggle('active', i === index);
        });
        currentSlide = index;
      }

      function nextSlide() {
        showSlide((currentSlide + 1) % totalSlides);
        clearInterval(slideInterval);
        slideInterval = setInterval(nextSlide, 5000);
      }

      function prevSlide() {
        showSlide((currentSlide - 1 + totalSlides) % totalSlides);
        clearInterval(slideInterval);
        slideInterval = setInterval(nextSlide, 5000);
      }

      function goToSlide(index) {
        showSlide(index);
        clearInterval(slideInterval);
        slideInterval = setInterval(nextSlide, 5000);
      }

      // Start automatic slideshow
      slideInterval = setInterval(nextSlide, 5000);

      // Cookie Banner
      function acceptCookies() {
        document.getElementById('cookie-banner').style.display = 'none';
        localStorage.setItem('cookiesAccepted', 'true');
      }

      function rejectCookies() {
        document.getElementById('cookie-banner').style.display = 'none';
        localStorage.setItem('cookiesAccepted', 'false');
      }

      // Check if user already made a choice
      if (localStorage.getItem('cookiesAccepted')) {
        document.getElementById('cookie-banner').style.display = 'none';
      }
    </script>
  </body>
</html>
